services:
  mysql:
    image: mysql:8.0
    restart: unless-stopped
    # DB kimlik bilgileri mevcut .env dosyasından okunur (yapı değiştirilmedi).
    environment:
      MYSQL_DATABASE: ${MYSQL_DATABASE}
      MYSQL_USER: ${MYSQL_USER}
      MYSQL_PASSWORD: ${MYSQL_PASSWORD}
      MYSQL_ROOT_PASSWORD: ${MYSQL_PASSWORD}
      # Konteynerler varsayılan olarak UTC'dir; sunucu ise Europe/Istanbul.
      # Eşitlenmezse uygulama zaman damgalarını 3 saat geriye yazar.
      TZ: ${TZ:-Europe/Istanbul}
    volumes:
      # MySQL verileri kalıcı volume'de tutulur
      - mysql_data:/var/lib/mysql
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 10s
      timeout: 5s
      retries: 10

  redis:
    image: redis:7-alpine
    restart: unless-stopped
    # Oturumlar kalıcı veri değil, TTL'li geçici durumdur; yine de yeniden
    # başlatmada aktif sohbetlerin düşmemesi için AOF açık tutulur.
    command: ["redis-server", "--appendonly", "yes"]
    volumes:
      - redis_data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 10

  app:
    build: .
    restart: unless-stopped
    # Tüm ortam değişkenleri mevcut .env dosyasından gelir.
    env_file: .env
    # Konteyner içinde MySQL, "localhost" yerine mysql servisine bağlanmalı.
    # load_dotenv(override=False) olduğu için bu değer .env'deki MYSQL_HOST'u ezer.
    environment:
      MYSQL_HOST: mysql
      # Oturum deposu: konteyner ağındaki redis servisi.
      REDIS_URL: redis://redis:6379/0
      # KRİTİK: conversation_logger ve dashboard_service zaman damgasını
      # datetime.now() ile üretir; bu da konteynerin saat dilimini kullanır.
      # UTC kalırsa kayıtlar 3 saat geriye yazılır ve panelde sıralama bozulur.
      TZ: ${TZ:-Europe/Istanbul}
    ports:
      # Yalnız localhost'a bağlanır: dışarıdan tek giriş nginx (TLS) üzerindendir.
      # "8000:8000" yazılsaydı Docker portu 0.0.0.0'a açar ve ufw kurallarını
      # atlayarak paneli TLS'siz olarak internete sunardı.
      - "127.0.0.1:8000:8000"
    depends_on:
      mysql:
        condition: service_healthy
      redis:
        condition: service_healthy
    # Uygulama her webhook'ta tüm JSON gövdesini bastığı için log hızlı büyür.
    # Sınırsız json-file sürücüsü diski doldurabilir; 3 x 10MB ile döndürülür.
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"

volumes:
  mysql_data:
  redis_data:
