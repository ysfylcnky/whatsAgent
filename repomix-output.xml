}
.pager button:hover:not(:disabled){ border-color:var(--border-strong); }
.pager button:disabled{ opacity:.4; cursor:not-allowed; }

.conv-empty{ color:var(--muted); font-size:14px; text-align:center; margin:auto; padding:40px; }
