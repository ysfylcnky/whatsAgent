    active_url = session["active_url"]

    lines = []

    active_context = products.get(active_url)

    if active_context:

        lines.append(
            "AKTİF ÜRÜN — "
            + active_context.get("name", "")
            + ": "
            + json.dumps(active_context, ensure_ascii=False)
        )

    others = []

    for url, ctx in products.items():

        if url == active_url:
            continue

        others.append(
