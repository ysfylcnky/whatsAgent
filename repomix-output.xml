            <div class="cust-summary">
                <div><span class="s-label">Telefon</span><span class="s-val">${this.esc(data.phone)}</span></div>
                <div><span class="s-label">İlk görülme</span><span class="s-val">${this.esc(data.first_seen || "—")}</span></div>
